# Doxyfile for the ds library
# Run with: doxygen Doxyfile

PROJECT_NAME           = "ds"
PROJECT_BRIEF          = "Header-only C++ implementations of classical data structures"
PROJECT_NUMBER         = 1.0.0
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

INPUT                  = include README.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = README.md

FILE_PATTERNS          = *.hpp *.h *.md
EXTENSION_MAPPING      = hpp=C++

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
INLINE_SIMPLE_STRUCTS  = YES

GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES
DISABLE_INDEX          = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES

HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES
